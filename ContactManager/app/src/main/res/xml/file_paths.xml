<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!--
        Exposes files written to getExternalFilesDir(null)/exports/
        so they can be shared via Intent without exposing the full filesystem.
    -->
    <external-files-path
        name="exports"
        path="exports/" />
</paths>
